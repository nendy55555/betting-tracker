# Betting Tracker — credential template
# Copy this file to `.env` in the same directory and fill in the values.
# NEVER commit `.env`; it is gitignored. Rotate credentials every 6-12 months.

# Locks25 sportsbook (Selenium scraper)
LOCKS25_USERNAME=
LOCKS25_PASSWORD=

# Bovada sportsbook (Selenium scraper)
BOVADA_EMAIL=
BOVADA_PASSWORD=

# The Odds API — paid plan, used by refresh_game_odds.py and the CLV pipeline.
# Leave blank to disable game-odds polling (the rest of the app still works).
ODDS_API_KEY=

# Optional: override the listen port for server.py (default 5001).
# BETTING_TRACKER_PORT=5001
